---
const currentPath = Astro.url.pathname;
---

<header class="bg-white border-b border-gray-100 sticky top-0 z-40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-9 h-9 bg-primary-500 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <span class="text-xl font-bold text-gray-900 group-hover:text-primary-500 transition-colors">
          PDF<span class="text-primary-500">Senior</span>
        </span>
      </a>

      <!-- Navigation -->
      <nav class="hidden md:flex items-center gap-1">
        <div class="relative group">
          <button class="flex items-center gap-1 px-4 py-2 text-sm font-semibold text-gray-700 hover:text-primary-500 rounded-lg hover:bg-gray-50 transition-colors">
            Outils PDF
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute top-full left-0 mt-1 w-56 bg-white rounded-xl shadow-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 p-2">
            <a href="/tools/merge" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-primary-50 hover:text-primary-600 rounded-lg transition-colors">Fusionner PDF</a>
            <a href="/tools/split" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-primary-50 hover:text-primary-600 rounded-lg transition-colors">Diviser PDF</a>
            <a href="/tools/compress" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-primary-50 hover:text-primary-600 rounded-lg transition-colors">Compresser PDF</a>
            <a href="/tools/rotate" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-primary-50 hover:text-primary-600 rounded-lg transition-colors">Pivoter PDF</a>
            <a href="/tools/watermark" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-primary-50 hover:text-primary-600 rounded-lg transition-colors">Filigrane PDF</a>
          </div>
        </div>

        <div class="relative group">
          <button class="flex items-center gap-1 px-4 py-2 text-sm font-semibold text-gray-700 hover:text-primary-500 rounded-lg hover:bg-gray-50 transition-colors">
            Convertir
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute top-full left-0 mt-1 w-56 bg-white rounded-xl shadow-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 p-2">
            <a href="/editor" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-primary-50 hover:text-primary-600 rounded-lg transition-colors">PDF en Word</a>
            <a href="/editor" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-primary-50 hover:text-primary-600 rounded-lg transition-colors">PDF en JPG / PNG</a>
            <a href="/tools/jpg-to-pdf" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-primary-50 hover:text-primary-600 rounded-lg transition-colors">JPG en PDF</a>
          </div>
        </div>

        <a href="/editor" class="px-4 py-2 text-sm font-semibold text-gray-700 hover:text-primary-500 rounded-lg hover:bg-gray-50 transition-colors">
          Signer PDF
        </a>
      </nav>

      <!-- Right side -->
      <div class="flex items-center gap-3">
        <a href="/pricing" class="hidden sm:inline-flex text-sm font-medium text-gray-600 hover:text-primary-500 transition-colors">
          Tarifs
        </a>
        <a href="/#tools" class="btn-primary !py-2 !px-5 text-sm">
          Tous les outils
        </a>
      </div>
    </div>
  </div>
</header>
