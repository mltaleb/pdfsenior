---
import UploadZone from './UploadZone.tsx';
---

<section class="bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Copy -->
      <div>
        <h1 class="text-4xl lg:text-5xl font-extrabold text-gray-900 leading-tight mb-6">
          Votre éditeur PDF et votre convertisseur PDF tout-en-un
        </h1>
        <p class="text-lg text-gray-600 mb-8 leading-relaxed">
          Modifiez, convertissez et signez des PDF en quelques secondes, avec tout ce dont vous avez besoin au même endroit.
        </p>

        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-700">Fonctionne sur n'importe quel appareil, à tout moment</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-700">Aucune installation nécessaire</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-700">Privé et sécurisé</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-700">Conserve la mise en page d'origine</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-700">Prend en charge tous les types de fichiers populaires</span>
          </li>
        </ul>
      </div>

      <!-- Right: Upload Zone -->
      <div>
        <UploadZone client:load />
      </div>
    </div>
  </div>
</section>
