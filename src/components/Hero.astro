---
import UploadZone from './UploadZone.tsx';
---

<section id="top" class="bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Copy -->
      <div>
        <h1 class="text-4xl lg:text-5xl font-extrabold text-gray-900 leading-tight mb-6">
          Tous vos outils PDF en un seul endroit
        </h1>
        <p class="text-lg text-gray-600 mb-8 leading-relaxed">
          Fusionnez, divisez, compressez, convertissez, signez et annotez vos PDF gratuitement. Rapide, securise et sans installation.
        </p>

        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-700">10 outils PDF gratuits et illimites</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-700">Traitement 100% dans votre navigateur</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-700">Aucun fichier envoye sur un serveur</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-700">Fonctionne sur tous les appareils</span>
          </li>
        </ul>
      </div>

      <!-- Right: Upload Zone -->
      <div>
        <UploadZone client:load />
      </div>
    </div>
  </div>
</section>
