          <li><a href="/editor" class="text-sm hover:text-primary-400 transition-colors">PDF en JPG</a></li>
          <li><a href="/tools/jpg-to-pdf" class="text-sm hover:text-primary-400 transition-colors">JPG en PDF</a></li>
