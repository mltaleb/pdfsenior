---

<section class="py-20 bg-white" id="tools">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
        Tous les outils PDF dont vous avez besoin
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Des outils puissants, gratuits et faciles a utiliser. Tout se passe dans votre navigateur.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 lg:gap-6">
      {tools.map((tool) => (
        <a
          href={tool.href}
          class={`group flex flex-col items-center text-center p-6 rounded-2xl border transition-all duration-300 cursor-pointer ${tool.lightColor}`}
        >
          <div class={`w-16 h-16 ${tool.color} rounded-2xl flex items-center justify-center mb-4 text-white shadow-md group-hover:scale-110 transition-transform duration-300`}>
            <Fragment set:html={tool.icon} />
          </div>
          <h3 class={`text-sm font-bold ${tool.textColor} mb-1`}>{tool.title}</h3>
          <p class="text-xs text-gray-500 leading-relaxed hidden sm:block">{tool.description}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- Trust section -->
<section class="py-16 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-3 gap-8">
      <div class="text-center">
        <div class="w-14 h-14 bg-primary-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">100% prive et securise</h3>
        <p class="text-sm text-gray-600">Vos fichiers restent sur votre appareil. Rien n'est envoye a un serveur.</p>
      </div>
      <div class="text-center">
        <div class="w-14 h-14 bg-primary-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Rapide et gratuit</h3>
        <p class="text-sm text-gray-600">Traitement instantane directement dans votre navigateur, sans limite.</p>
      </div>
      <div class="text-center">
        <div class="w-14 h-14 bg-primary-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Tous les appareils</h3>
        <p class="text-sm text-gray-600">Fonctionne sur ordinateur, tablette et mobile, sans installation.</p>
      </div>
    </div>
  </div>
</section>
