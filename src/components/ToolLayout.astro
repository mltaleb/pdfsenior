---
interface Props {
  title: string;
  description: string;
  color: string;
  icon: string;
}
const { title, description, color, icon } = Astro.props;
---

<div class="min-h-[calc(100vh-64px)] bg-gray-50 flex flex-col">
  <!-- Tool header -->
  <div class="bg-white border-b border-gray-200 py-8">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <div class={`w-16 h-16 ${color} rounded-2xl flex items-center justify-center mx-auto mb-4 text-white shadow-md`}>
        <Fragment set:html={icon} />
      </div>
      <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-2">{title}</h1>
      <p class="text-gray-600">{description}</p>
    </div>
  </div>

  <!-- Tool content -->
  <div class="flex-1 py-10">
    <div class="max-w-4xl mx-auto px-4">
      <slot />
    </div>
  </div>
</div>
