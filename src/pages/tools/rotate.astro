---
import Layout from '../../layouts/Layout.astro';
import ToolLayout from '../../components/ToolLayout.astro';
import RotatePdf from '../../components/tools/RotatePdf.tsx';
---

<Layout title="Pivoter PDF - PDFSenior" description="Faites pivoter les pages de vos PDF gratuitement en ligne.">
  <ToolLayout
    title="Pivoter les pages d'un PDF"
    description="Faites pivoter les pages individuellement ou toutes en meme temps. Cliquez sur une page pour la pivoter de 90 degres."
    color="bg-cyan-500"
    icon='<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182" /></svg>'
  >
    <RotatePdf client:load />
  </ToolLayout>
</Layout>
