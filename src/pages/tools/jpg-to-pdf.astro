---
import Layout from '../../layouts/Layout.astro';
import ToolLayout from '../../components/ToolLayout.astro';
import JpgToPdf from '../../components/tools/JpgToPdf.tsx';
---

<Layout title="JPG en PDF - PDFSenior" description="Convertissez vos images JPG et PNG en un document PDF gratuitement.">
  <ToolLayout
    title="Convertir des images en PDF"
    description="Glissez-deposez vos images JPG ou PNG et convertissez-les en un seul document PDF."
    color="bg-purple-500"
    icon='<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" /></svg>'
  >
    <JpgToPdf client:load />
  </ToolLayout>
</Layout>
