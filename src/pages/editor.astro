---
import Layout from '../layouts/Layout.astro';
import EditorToolbar from '../components/EditorToolbar.tsx';
import PageThumbnails from '../components/PageThumbnails.tsx';
import PdfEditor from '../components/PdfEditor.tsx';
import ExportModal from '../components/ExportModal.tsx';
---

<Layout title="Éditeur PDF - PDFSenior" hideFooter={true}>
  <div class="h-[calc(100vh-64px)] flex flex-col">
    <EditorToolbar client:load />
    <div class="flex flex-1 overflow-hidden">
      <PageThumbnails client:load />
      <PdfEditor client:load />
    </div>
  </div>
  <ExportModal client:load />
</Layout>

<script>
  import { setPaid, $showExportModal, $pdfBytes } from '../stores/app-store';
  import { loadPendingDownload, clearPendingDownload, triggerDownload } from '../lib/download';

  const params = new URLSearchParams(window.location.search);
  if (params.get('payment') === 'success') {
    const planId = localStorage.getItem('pdfsenior_selected_plan') || 'day-pass';
    setPaid(planId);
    const url = new URL(window.location.href);
    url.searchParams.delete('payment');
    url.searchParams.delete('session_id');
    window.history.replaceState({}, '', url.toString());

    loadPendingDownload().then(pending => {
      if (pending) {
        triggerDownload(pending.bytes, pending.fileName);
        clearPendingDownload();
      } else {
        const unsub = $pdfBytes.listen(bytes => {
          if (bytes) {
            unsub();
            $showExportModal.set(true);
          }
        });
        setTimeout(() => unsub(), 10000);
      }
    }).catch(() => {});
  }
</script>
