---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
---

<Layout title="PDFSenior - Outils PDF Gratuits en Ligne" description="Fusionnez, divisez, compressez, convertissez et signez vos PDF gratuitement. 10 outils PDF en ligne, rapides et securises.">
  <Hero />
  <Features />

  <!-- CTA Section -->
  <section class="bg-cream py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
        Pret a travailler avec vos PDF ?
      </h2>
      <p class="text-lg text-gray-600 mb-8">
        Choisissez un outil et commencez en quelques secondes. Aucune inscription requise.
      </p>
      <a href="/#tools" class="btn-primary inline-flex items-center gap-2">
        Voir tous les outils
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </section>
</Layout>
